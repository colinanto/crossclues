rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // --- Entity Validations ---

    function isValidGame(data) {
      return data.keys().hasAll(['hostId', 'status', 'words', 'createdAt']) 
        && data.keys().size() == 4
        && data.hostId == request.auth.uid
        && data.status in ['lobby', 'in-progress', 'finished']
        && data.words is map
        && data.createdAt == request.time;
    }

    function isValidPlayer(data) {
      return data.keys().hasAll(['uid', 'name', 'isReady', 'assignedCoordinate'])
        && data.keys().size() == 4
        && data.uid == request.auth.uid
        && data.name is string && data.name.size() <= 50
        && data.isReady is bool
        && (data.assignedCoordinate == null || (data.assignedCoordinate is string && data.assignedCoordinate.matches('^[A-E][1-5]$')));
    }

    function isValidClue(data) {
      return data.keys().hasAll(['authorId', 'clue', 'coordinate', 'createdAt'])
        && data.keys().size() == 4
        && data.authorId == request.auth.uid
        && data.clue is string && data.clue.size() <= 100
        && data.coordinate is string && data.coordinate.matches('^[A-E][1-5]$')
        && data.createdAt == request.time;
    }

    // --- Match blocks ---

    match /games/{gameId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // In a real app we might want to restrict this to games where user is a player, but for a global lobby list (if any) it's okay for now.
      
      allow create: if isSignedIn() && isValidId(gameId) && isValidGame(incoming());
      
      allow update: if isSignedIn() && (
        // Host can update status
        (isOwner(existing().hostId) && incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        // Players can join (this logic might need a shared mapping, but for now we rely on the subcollection approach)
        false
      );

      allow delete: if isSignedIn() && isOwner(existing().hostId);

      // Sub-collections
      match /players/{playerId} {
        allow get: if isSignedIn();
        allow list: if isSignedIn();
        allow create: if isSignedIn() && isOwner(playerId) && isValidPlayer(incoming());
        allow update: if isSignedIn() && isOwner(playerId) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'isReady', 'assignedCoordinate']);
        allow delete: if isSignedIn() && isOwner(playerId);
      }

      match /clues/{clueId} {
        allow get, list: if isSignedIn(); // Clues are shared within the game
        allow create: if isSignedIn() && isValidClue(incoming()) && exists(/databases/$(database)/documents/games/$(gameId)/players/$(request.auth.uid));
        // Clues are immutable
        allow update, delete: if false;
      }
    }
  }
}
